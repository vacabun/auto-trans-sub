OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://your-proxy.example/v1
ASR_BACKEND=mlx
WHISPER_MODEL_REPO=mlx-community/whisper-large-v3-mlx
# For Apple Silicon + Japanese ASR, you can try:
# WHISPER_MODEL_REPO=kaiinui/kotoba-whisper-v2.0-mlx
# For faster-whisper:
# ASR_BACKEND=faster-whisper
# WHISPER_MODEL_REPO=large-v3
# FASTER_WHISPER_DEVICE=auto
# FASTER_WHISPER_COMPUTE_TYPE=auto
# FASTER_WHISPER_BEAM_SIZE=5
